<Window x:Class="PomodoroPet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PomodoroPet"
        mc:Ignorable="d"
        Title="番茄钟" Height="470" Width="320"
        Icon="Assets/icon.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF6EE">
    <Window.Resources>
        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Background" Value="#FF8A65"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource RoundButton}">
            <Setter Property="Background" Value="#FFE0CC"/>
            <Setter Property="Foreground" Value="#B5502E"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🍅 番茄钟" FontSize="22" FontWeight="Bold"
                   Foreground="#B5502E" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="20,16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="StateLabel" Text="待机中" FontSize="14" Foreground="#B5502E"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="TimeLabel" Text="25:00" FontSize="56" FontWeight="Bold"
                           Foreground="#3E2723" HorizontalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock x:Name="SessionLabel" Text="已完成 0 个番茄" FontSize="12" Foreground="#8D6E63"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
            <Button x:Name="StartPauseButton" Content="开始" Width="90" Margin="0,0,10,0"
                    Style="{StaticResource RoundButton}" Click="StartPauseButton_Click"/>
            <Button x:Name="ResetButton" Content="重置" Width="90"
                    Style="{StaticResource GhostButton}" Click="ResetButton_Click"/>
        </StackPanel>

        <Border Grid.Row="3" Background="White" CornerRadius="16" Padding="16,10" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="专注时长(分钟)" FontSize="11" Foreground="#8D6E63" Margin="0,0,0,4"/>
                    <TextBox x:Name="WorkMinutesBox" Text="25" FontSize="14" Padding="6,4"
                             TextAlignment="Center" LostFocus="DurationBox_LostFocus"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="休息时长(分钟)" FontSize="11" Foreground="#8D6E63" Margin="0,0,0,4"/>
                    <TextBox x:Name="BreakMinutesBox" Text="5" FontSize="14" Padding="6,4"
                             TextAlignment="Center" LostFocus="DurationBox_LostFocus"/>
                </StackPanel>
            </Grid>
        </Border>

        <Button Grid.Row="6" Content="🔽 缩小为迷你小屏幕" Style="{StaticResource GhostButton}"
                Click="ShrinkButton_Click" HorizontalAlignment="Stretch" Padding="0,10"/>
    </Grid>
</Window>
